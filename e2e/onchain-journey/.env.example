# On-chain journey harness — environment. Copy to .env (gitignored) to override.
# NONE of these are read by the Next app or baked into the build; they are read
# only by the test process. Never put a real/funded key here for the fork mode.

# JSON-RPC the injected wallet signs/broadcasts/reads against (the anvil fork).
TEST_RPC_URL=http://localhost:8546

# In-process signer. Default (set in run.sh) is anvil dev account #0 — public,
# auto-funded on the fork. Override only for an advanced/live run.
# TEST_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Where the unmodified static export is served.
TEST_BASE_URL=http://localhost:4173

# Upstream Gnosis RPC that anvil forks from (used by run.sh, not the browser).
FORK_RPC_URL=https://rpc.gnosischain.com

# Optional: use a specific Chromium binary instead of Playwright's managed one.
# PW_EXECUTABLE_PATH=/path/to/Chromium
