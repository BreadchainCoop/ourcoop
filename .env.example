ETH_RPC_URL=https://rpc.gnosis.gateway.fm
# ETH_BLOCK_NUMBER is optional - if not provided, tests will use the latest block
# ETH_BLOCK_NUMBER=32661487

# Privy app id. Set to enable embedded wallets + native ("App pays", EIP-7702)
# gas sponsorship, so cross-chain governance is submitted gaslessly from the
# browser (no relay server). Enable the target chains' sponsorship in the Privy
# dashboard. Empty = plain injected wallet (local dev + e2e), self-paid gas.
NEXT_PUBLIC_PRIVY_APP_ID=
# NEXT_PUBLIC_PRIVY_CLIENT_ID=
